# Google Gemini API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-key-here

# Optional service settings
API_URL=http://localhost:8000
# MLFLOW_TRACKING_URI defaults to local data/mlruns.
# MLFLOW_EXPERIMENT_NAME=hr-agent

# Tavily for Search Tool
TAVILY_API_KEY=your-key-here

# LLM backend: "gemini" (default) or "ollama" (self-hosted, no Gemini free-tier
# daily request cap). Only affects chat/reasoning — RAG embeddings and answer
# generation stay on Gemini either way.
# LLM_PROVIDER=gemini
# OLLAMA_URL=http://localhost:11434
# OLLAMA_CHAT_MODEL=gemma4:e4b

# Optional -- HR escalation email notifications (src/agent/tools.py:escalate_to_hr).
# If SMTP_HOST or HR_ESCALATION_EMAIL_TO is left unset, escalations fall back
# automatically to a local mock outbox at data/escalation_outbox.jsonl -- no
# runtime error, safe for zero-key local dev and live demos.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=your-smtp-username
# SMTP_PASSWORD=your-smtp-password
# HR_ESCALATION_EMAIL_TO=hr-team@example.com
# HR_ESCALATION_EMAIL_FROM=hr-agent@example.com