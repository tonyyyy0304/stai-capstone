# Google Gemini API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-key-here

# Optional service settings
API_URL=http://localhost:8000
# MLFLOW_TRACKING_URI defaults to local data/mlruns.
# MLFLOW_EXPERIMENT_NAME=hr-agent

# Tavily for Search Tool
TAVILY_API_KEY=your-key-here

# LLM backend: "gemini" (default) or "ollama" (self-hosted, no Gemini free-tier
# daily request cap). Only affects chat/reasoning — RAG embeddings and answer
# generation stay on Gemini either way.
# LLM_PROVIDER=gemini
# OLLAMA_URL=http://localhost:11434
# OLLAMA_CHAT_MODEL=gemma4:e4b
