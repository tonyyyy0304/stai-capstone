FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /app

COPY requirements-mlflow.txt .
RUN pip install -r requirements-mlflow.txt

COPY scripts/render_mlflow_start.sh scripts/render_mlflow_start.sh

EXPOSE 5000

CMD ["sh", "scripts/render_mlflow_start.sh"]
